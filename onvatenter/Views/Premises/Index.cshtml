@model IEnumerable<Premises>
@{
    ViewData["Title"] = "Premises";
}

<h1>Premises</h1>
<a href="/Premises/Create" class="btn btn-primary mb-3">Add New</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk Rating</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model ?? new List<Premises>())
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.Address</td>
                <td>@p.Town</td>
                <td>@p.RiskRating</td>
                <td>
                    <a href="/Premises/Details/@p.Id" class="btn btn-sm btn-info">View</a>
                    <a href="/Premises/Edit/@p.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a href="/Premises/Delete/@p.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
