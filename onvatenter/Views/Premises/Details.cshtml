@model Premises
@{
    ViewData["Title"] = "Premises Details";
}

<h1>@Model.Name</h1>

<div class="card">
    <div class="card-body">
        <p><strong>Address:</strong> @Model.Address</p>
        <p><strong>Town:</strong> @Model.Town</p>
        <p><strong>Risk Rating:</strong> @Model.RiskRating</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToString("yyyy-MM-dd")</p>
    </div>
</div>

<div class="mt-3">
    <a href="/Premises" class="btn btn-secondary">Back</a>
    <a href="/Premises/Edit/@Model.Id" class="btn btn-warning">Edit</a>
    <a href="/Premises/Delete/@Model.Id" class="btn btn-danger">Delete</a>
</div>
