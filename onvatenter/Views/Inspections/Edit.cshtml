@model Inspection
@{
    ViewData["Title"] = "Edit Inspection";
}

<h1>Edit Inspection</h1>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id">
    <div class="mb-3">
        <label for="PremisesId" class="form-label">Premises</label>
        <select class="form-select" id="PremisesId" name="PremisesId" required>
            @foreach (var p in ViewBag.Premises ?? new List<dynamic>())
            {
                <option value="@p.Value" selected="@(p.Value.ToString() == Model.PremisesId.ToString())">@p.Text</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label for="InspectionDate" class="form-label">Date</label>
        <input type="date" class="form-control" id="InspectionDate" name="InspectionDate" value="@Model.InspectionDate.ToString("yyyy-MM-dd")" required>
    </div>
    <div class="mb-3">
        <label for="Score" class="form-label">Score</label>
        <input type="number" class="form-control" id="Score" name="Score" value="@Model.Score" min="0" max="100" required>
    </div>
    <div class="mb-3">
        <label for="Outcome" class="form-label">Outcome</label>
        <select class="form-select" id="Outcome" name="Outcome" required>
            <option value="Pass" selected="@(Model.Outcome == "Pass")">Pass</option>
            <option value="Pass with Observations" selected="@(Model.Outcome == "Pass with Observations")">Pass with Observations</option>
            <option value="Fail" selected="@(Model.Outcome == "Fail")">Fail</option>
        </select>
    </div>
    <div class="mb-3">
        <label for="Notes" class="form-label">Notes</label>
        <textarea class="form-control" id="Notes" name="Notes" rows="3">@Model.Notes</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/Inspections" class="btn btn-secondary">Cancel</a>
</form>
