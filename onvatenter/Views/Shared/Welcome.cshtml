@{
    ViewData["Title"] = "Welcome";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="jumbotron bg-light p-5 rounded-lg mb-4">
                <h1 class="display-5 fw-bold">Food Safety Inspection Tracker</h1>
                <p class="fs-5">Professional inspection management for food premises</p>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Track Inspections</h5>
                            <p class="card-text">Record and manage food safety inspections with detailed scoring and outcomes.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Monitor Follow-ups</h5>
                            <p class="card-text">Track follow-up actions and identify overdue items automatically.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Dashboard Analytics</h5>
                            <p class="card-text">View comprehensive dashboards with filtering by town and risk rating.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Role-Based Access</h5>
                            <p class="card-text">Secure role-based access for Admin, Inspector, and Viewer roles.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <h4 class="alert-heading">Default Login Credentials</h4>
                <p>Use one of these accounts to log in:</p>
                <ul class="mb-0">
                    <li>Admin: admin@foodsafety.local / Admin123!</li>
                    <li>Inspector: inspector@foodsafety.local / Inspector123!</li>
                    <li>Viewer: viewer@foodsafety.local / Viewer123!</li>
                </ul>
            </div>

            <div class="mt-4">
                <a href="/dashboard" class="btn btn-primary btn-lg me-2">View Dashboard</a>
                <a href="/premises" class="btn btn-secondary btn-lg">Browse Premises</a>
            </div>
        </div>
    </div>
</div>
