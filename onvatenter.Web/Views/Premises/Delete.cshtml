@model Premises
@{
    ViewData["Title"] = "Delete Premises";
}

<h1>Delete @Model.Name?</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this premises?
</div>

<form method="post" action="/Premises/DeleteConfirmed/@Model.Id">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/Premises" class="btn btn-secondary">Cancel</a>
</form>
