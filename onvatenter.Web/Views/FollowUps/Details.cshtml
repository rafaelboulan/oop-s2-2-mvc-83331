@model FollowUp
@{
    ViewData["Title"] = "Follow-up Details";
}

<h1>Follow-up Details</h1>

<div class="card">
    <div class="card-body">
        <p>
            <strong>Inspection:</strong>
            #@Model.InspectionId
            <br />
            <span class="text-muted">
                @Model.Inspection?.Premises?.Name
            </span>
        </p>
        <p><strong>Due Date:</strong> @Model.DueDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Status:</strong> @Model.Status</p>
        @if (Model.ClosedDate.HasValue)
        {
            <p><strong>Closed Date:</strong> @Model.ClosedDate.Value.ToString("yyyy-MM-dd")</p>
        }
    </div>
</div>

<div class="mt-3">
    <a href="/FollowUps" class="btn btn-secondary">Back</a>
    <a href="/FollowUps/Edit/@Model.Id" class="btn btn-warning">Edit</a>
    <a href="/FollowUps/Delete/@Model.Id" class="btn btn-danger">Delete</a>
</div>
