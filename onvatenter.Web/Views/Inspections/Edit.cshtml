@model Inspection

@{
    ViewData["Title"] = "Edit Inspection";
}

<h1>Edit Inspection</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="PremisesId" class="form-label">Premises</label>
        <select asp-for="PremisesId" class="form-select" asp-items="ViewBag.Premises" required>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="InspectionDate" class="form-label">Date</label>
        <input asp-for="InspectionDate" type="date" class="form-control" required />
    </div>

    <div class="mb-3">
        <label asp-for="Score" class="form-label">Score</label>
        <input asp-for="Score" type="number" class="form-control" min="0" max="100" required />
    </div>

    <div class="mb-3">
        <label asp-for="Outcome" class="form-label">Outcome</label>
        <select asp-for="Outcome" class="form-select" required>
            <option value="Pass">Pass</option>
            <option value="Pass with Observations">Pass with Observations</option>
            <option value="Fail">Fail</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Notes</label>
        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>