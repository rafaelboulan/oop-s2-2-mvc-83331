@model Inspection
@{
    ViewData["Title"] = "Inspection Details";
}

<h1>Inspection Details</h1>

<div class="card">
    <div class="card-body">
        <p><strong>Premises:</strong> @Model.Premises?.Name</p>
        <p><strong>Date:</strong> @Model.InspectionDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Score:</strong> @Model.Score</p>
        <p><strong>Outcome:</strong> @Model.Outcome</p>
        <p><strong>Notes:</strong> @Model.Notes</p>
    </div>
</div>

<div class="mt-3">
    <a href="/Inspections" class="btn btn-secondary">Back</a>
    <a href="/Inspections/Edit/@Model.Id" class="btn btn-warning">Edit</a>
    <a href="/Inspections/Delete/@Model.Id" class="btn btn-danger">Delete</a>
</div>
