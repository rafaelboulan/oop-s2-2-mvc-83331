@model IEnumerable<Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<h1>Inspections</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Add New</a>

<table class="table">
    <thead>
        <tr>
            <th>Premises</th>
            <th>Date</th>
            <th>Score</th>
            <th>Outcome</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var i in Model)
            {
                <tr>
                    <td>@i.Premises?.Name</td>
                    <td>@i.InspectionDate.ToString("yyyy-MM-dd")</td>
                    <td>@i.Score</td>
                    <td>@i.Outcome</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@i.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-action="Edit" asp-route-id="@i.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@i.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    No inspections found
                </td>
            </tr>
        }
    </tbody>
</table>