@model Inspection
@{
    ViewData["Title"] = "Delete Inspection";
}

<h1>Delete Inspection?</h1>

<div class="alert alert-warning">
    Are you sure you want to delete this inspection?
</div>

<form method="post" action="/Inspections/DeleteConfirmed/@Model.Id">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/Inspections" class="btn btn-secondary">Cancel</a>
</form>
